# Copy this file to .env and fill in real values.
# .env is gitignored — never commit actual secrets.

NODE_ENV=development
PORT=4000

# PostgreSQL connection string. connection_limit tuned for MVP scale
# per Architecture Document Section 4.5 (Connection Pooling).
DATABASE_URL="postgresql://collabspace:collabspace@localhost:5432/collabspace?connection_limit=10&pool_timeout=10"

# Redis connection string (JWT refresh store, rate limiting, queues, Socket.io adapter)
REDIS_URL="redis://localhost:6379"

# JWT signing keys (RS256, per Architecture Document Section 6.1).
# Generate a keypair with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then base64-encode each (preserves newlines through .env parsing):
#   base64 -i private.pem | tr -d '\n'
#   base64 -i public.pem  | tr -d '\n'
JWT_PRIVATE_KEY_BASE64=""
JWT_PUBLIC_KEY_BASE64=""
JWT_ACCESS_TOKEN_TTL="15m"
JWT_REFRESH_TOKEN_TTL_DAYS=30

# Must match the frontend's dev server origin exactly (credentials: true
# requires an explicit origin, not a wildcard)
CORS_ORIGIN="http://localhost:5173"

# Used to sign cookies (e.g. refresh_token). Min 16 characters.
# Generate with: openssl rand -hex 32
COOKIE_SECRET="change-this-to-a-random-32-byte-hex-string"
